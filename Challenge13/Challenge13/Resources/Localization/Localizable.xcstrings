    "Find my items with ${applicationName}": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Find my items with ${applicationName}"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "${applicationName} से मेरी चीज़ें ढूंढो"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Encontrar meus objetos com ${applicationName}"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用 ${applicationName} 找我的物品"
          }
        }
      }
    },
    "Find object in ${applicationName}": {
      "extractionState": "manual",
      "localizations": {
