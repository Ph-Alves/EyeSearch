    "hints.card.widgets.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add EyeSearch to the Lock Screen for faster camera access."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कैमरा तेज़ी से ऐक्सेस करने के लिए EyeSearch को लॉक स्क्रीन में जोड़ें।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Adicione o EyeSearch à tela de bloqueio para acessar a câmera com mais rapidez."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将 EyeSearch 添加到锁定屏幕，以便更快地访问相机。"
          }
        }
      }
    },
    "hints.card.widgets.title": {
