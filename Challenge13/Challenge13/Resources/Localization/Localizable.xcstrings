    "Aprenda como usar o EyeSearch de forma simples com as dicas ou com o EyeChat.": {
      "comment": "A description under the \"Dicas\" title, explaining how to use the app with hints or with EyeChat.",
      "extractionState": "stale",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Learn how to use EyeSearch easily with the hints or with EyeChat."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Aprenda como usar o EyeSearch de forma simples com as dicas ou com o EyeChat."
          }
        }
      }
    },
    "Buscar objeto": {
      "comment": "AppIntents — título da intent exibido na Siri e nos Atalhos.",
      "extractionState": "manual"
    },
    "chat.accessibility.assistantSaid": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Assistant responded"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सहायक ने उत्तर दिया"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Assistente respondeu"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "助手回复"
          }
        }
      }
    },
    "chat.accessibility.filteredSuffix": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": " (out of scope message)"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "(दायरे से बाहर संदेश)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": " (mensagem fora do escopo)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "（超出范围的消息）"
          }
        }
      }
    },
    "chat.accessibility.loading": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Assistant is typing, please wait."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सहायक टाइप कर रहा है, कृपया प्रतीक्षा करें।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Assistente está digitando, aguarde."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "助手正在输入，请稍候。"
          }
        }
      }
    },
    "chat.accessibility.userSaid": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You said"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपने कहा"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você disse"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您说"
          }
        }
      }
    },
    "chat.error.emptyResponse": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not generate a response. Try rephrasing your question."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उत्तर नहीं मिल सका। कृपया अपना प्रश्न दोबारा लिखें।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não consegui gerar uma resposta. Tente reformular sua pergunta."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法生成回复，请尝试重新表述您的问题。"
          }
        }
      }
    },
    "chat.error.modelUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The assistant is unavailable. Please check if Apple Intelligence is enabled in Settings."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सहायक अभी उपलब्ध नहीं है। कृपया सेटिंग में Apple Intelligence सक्षम करें।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O assistente não está disponível no momento. Verifique se o Apple Intelligence está ativado nas configurações."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "助手目前不可用。请在设置中检查 Apple Intelligence 是否已开启。"
          }
        }
      }
    },
    "chat.error.offTopic": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I can only help with topics related to low vision, visual accessibility, and EyeSearch features."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मैं केवल कम दृष्टि, दृश्य पहुँच और EyeSearch सुविधाओं से संबंधित विषयों में सहायता कर सकता हूँ।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Só posso ajudar com temas relacionados a baixa visão, acessibilidade visual e funcionalidades do app."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我只能帮助与低视力、视觉辅助功能和 EyeSearch 相关的问题。"
          }
        }
      }
    },
    "chat.error.scopeDenial": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sorry, I can only help with topics related to visual accessibility and EyeSearch features. Do you have any questions about that?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्षमा करें, मैं केवल दृश्य पहुँच और EyeSearch से संबंधित विषयों में सहायता कर सकता हूँ।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desculpe, só consigo ajudar com assuntos relacionados à acessibilidade visual e funcionalidades do EyeSearch. Tem alguma dúvida sobre isso que eu possa responder?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "抱歉，我只能帮助解答与视觉辅助功能和 EyeSearch 相关的问题。"
          }
        }
      }
    },
    "chat.error.sessionFailed %@": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Session error: %@"
