    "hints.card.siri.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Say \"Hey Siri, find my items with EyeSearch\" to open the app ready to search."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऐप खोलने के लिए कहें \"अरे Siri, EyeSearch से मेरी चीज़ें ढूंढो।\""
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Diga \"Ei Siri, encontrar meus objetos com EyeSearch\" para abrir o app pronto para buscar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "说\"嘿 Siri，用 EyeSearch 找我的物品\"，即可打开应用开始搜索。"
          }
        }
      }
    },
