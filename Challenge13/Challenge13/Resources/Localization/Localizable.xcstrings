    "hints.screen.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Learn how to use EyeSearch easily with the hints or with EyeChat."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टिप्स या EyeChat के साथ EyeSearch को आसानी से उपयोग करना सीखें।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aprenda como usar o EyeSearch de forma simples com as dicas ou com o EyeChat."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过提示或 EyeChat 轻松学习如何使用 EyeSearch。"
          }
        }
