    "hints.card.siri.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Say \"Hey Siri, find my items\" to open EyeSearch ready to search."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "EyeSearch खोलने के लिए कहें \"अरे Siri, मेरी चीज़ें ढूंढो।\""
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diga \"Ei Siri, encontrar meus objetos\" para abrir o EyeSearch pronto para buscar."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "说\"嘿 Siri，找我的物品\"，即可打开 EyeSearch 开始搜索。"
          }
        }
      }
    },
    "hints.card.siri.title" : {
      "extractionState" : "manual",
