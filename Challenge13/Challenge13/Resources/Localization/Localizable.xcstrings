    "hints.screen.chat.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get answers with EyeChat, EyeSearch's Artificial Intelligence."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "EyeSearch की आर्टिफिशियल इंटेलिजेंस EyeChat से अपने सवालों के जवाब पाएं।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tire dúvidas com o EyeChat, a Inteligência Artificial do EyeSearch."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过 EyeSearch 的人工智能 EyeChat 获取解答。"
          }
        }
      }
    },
    "hints.screen.chat.title": {
