    "%lld": {
      "comment": "A text view displaying the current quantity of items in a cart or similar context.",
      "isCommentAutoGenerated": true
    },
    "Abre a tela de busca de objetos pela câmera.": {
      "comment": "AppIntents — descrição da intent exibida no app Atalhos e na Siri.",
      "extractionState": "manual"
    },
