            "state" : "translated",
            "value" : "कैमरा तेज़ी से ऐक्सेस करने के लिए EyeSearch को लॉक स्क्रीन या कंट्रोल सेंटर में जोड़ें।"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
