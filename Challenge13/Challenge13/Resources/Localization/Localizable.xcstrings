          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "贴纸"
          }
        }
      }
    },
    "hints.card.text.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "EyeSearch adapts to the text size set on your device."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "EyeSearch आपके डिवाइस पर सेट किए गए टेक्स्ट आकार के अनुसार अनुकूलित होता है।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O EyeSearch se adapta ao tamanho de texto definido no seu dispositivo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "EyeSearch 会适应您设备上设置的文字大小。"
          }
        }
      }
    },
    "hints.card.text.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Text"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टेक्स्ट"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
