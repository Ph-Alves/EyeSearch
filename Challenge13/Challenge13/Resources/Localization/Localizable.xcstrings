          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha na sessão: %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "会话错误：%@"
          }
        }
      }
    },
    "chat.input.placeholder": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ask a question about accessibility…"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यहाँ अपना प्रश्न लिखें"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Insira sua pergunta aqui"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在此输入您的问题"
          }
        }
      }
    },
    "common.button.back": {
      "extractionState": "manual",
      "localizations": {
