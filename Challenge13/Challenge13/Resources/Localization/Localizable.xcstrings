    "hints.card.stickers.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Download the sticker sheet and print it. Attach the stickers to the objects you want to find. EyeSearch's camera identifies the stickers from up to 2 meters away and alerts you when the item is located."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्टिकर शीट डाउनलोड करें और प्रिंट करें। उन वस्तुओं पर चिपकाएं जिन्हें आप ढूंढना चाहते हैं। EyeSearch का कैमरा 2 मीटर तक के स्टिकर पहचानता है और आइटम मिलने पर आपको सूचित करता है।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Baixe a folha de adesivos e imprima. Cole nos objetos que deseja encontrar. A câmera do EyeSearch identifica os adesivos a até 2 metros e avisa quando o item for localizado."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下载贴纸表并打印。将贴纸粘贴到您想找到的物品上。EyeSearch 的摄像头可识别 2 米内的贴纸，并在找到物品时提醒您。"
          }
        }
      }
    },
    "hints.card.stickers.title": {
      "extractionState": "manual",
      "localizations": {
