          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文字"
          }
        }
      }
    },
    "hints.card.voiceOver.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "EyeSearch is compatible with VoiceOver and respects the active settings on your device."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "EyeSearch, VoiceOver के साथ संगत है और आपके डिवाइस की सक्रिय सेटिंग्स का पालन करता है।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O EyeSearch é compatível com o VoiceOver e respeita as configurações ativas no seu dispositivo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "EyeSearch 与 VoiceOver 兼容，并遵循您设备上的活动设置。"
          }
        }
      }
    },
    "hints.card.voiceOver.title": {
