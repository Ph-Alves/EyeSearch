    "sticker.screen.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is the sticker that will identify your objects.\nChoose how many you want to print."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह वह स्टिकर है जो आपकी वस्तुओं की पहचान करेगा।\nआप जितनी मात्रा में प्रिंट करना चाहते हैं उसे चुनें।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este é o adesivo que identificará seus objetos.\nEscolha a quantidade que deseja imprimir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这是用于识别您物品的贴纸。\n请选择您想打印的数量。"
          }
        }
      }
    }
